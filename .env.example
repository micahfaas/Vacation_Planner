# Copy to .env and fill in your Supabase project values.
# Found in the Supabase dashboard under Settings -> API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Note: AeroDataBox flight lookup runs through the flight-lookup Supabase
# Edge Function — its API key is a server-side secret (supabase secrets set
# AERODATABOX_KEY=...), not a Vite env var.

# Web push (booking reminders): the VAPID PUBLIC key. Safe to expose. Generate
# a pair with `npx web-push generate-vapid-keys`; the PRIVATE key goes to
# Supabase secrets (VAPID_PRIVATE_KEY), not here. Add this as a GitHub repo
# variable for CI too. Without it, push reminders stay disabled.
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Optional: Google OAuth client ID for the "Connect Google Calendar" import.
# Create one at console.cloud.google.com (OAuth client, type "Web
# application") with this app's origin as an authorized JavaScript origin.
# Without it, that import method stays hidden. Add it as a GitHub repo
# variable for CI too.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id

# Optional: PostHog product analytics (privacy-first, cookieless — see
# src/analytics.js). The project API key is public by design (it can only write
# events, never read them). Find it in PostHog under Settings -> Project ->
# Project API key; it starts with "phc_". Add it as a GitHub repo variable for
# CI too. Without it — or while ANALYTICS_LIVE is false in src/analytics.js —
# analytics stays completely off and posthog-js is never downloaded.
VITE_POSTHOG_KEY=phc_your-project-api-key
# Only if your PostHog project is on EU cloud. Defaults to US.
# VITE_POSTHOG_HOST=https://eu.i.posthog.com
