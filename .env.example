# Copy to .env and fill in your Supabase project values.
# Found in the Supabase dashboard under Settings -> API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: RapidAPI key for AeroDataBox flight lookup. Without it, the
# "Look up flight times" button stays hidden. Subscribe to AeroDataBox at
# rapidapi.com to get a key. For CI, also add it as a GitHub repo variable.
VITE_AERODATABOX_KEY=your-rapidapi-aerodatabox-key
