# Copy to .env and fill in your Supabase project values.
# Found in the Supabase dashboard under Settings -> API.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Note: AeroDataBox flight lookup runs through the flight-lookup Supabase
# Edge Function — its API key is a server-side secret (supabase secrets set
# AERODATABOX_KEY=...), not a Vite env var.

# Optional: Google OAuth client ID for the "Connect Google Calendar" import.
# Create one at console.cloud.google.com (OAuth client, type "Web
# application") with this app's origin as an authorized JavaScript origin.
# Without it, that import method stays hidden. Add it as a GitHub repo
# variable for CI too.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id
